{
  "name": "banglakit-word-addin",
  "version": "0.1.0",
  "private": true,
  "description": "Word Task Pane add-in that converts Bijoy-encoded runs to Unicode Bengali in place, using banglakit-wasm.",
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/banglakit-wasm --target web --release --out-dir ../../examples/word-addin/wasm-pkg",
    "build": "npm run build:wasm && webpack --mode production",
    "dev-server": "npm run build:wasm && webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
